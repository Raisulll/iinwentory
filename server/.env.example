# ── Database ────────────────────────────────────────────────────────────
# Local dev (docker-compose up):
#   postgresql://iinwentory:iinwentory@localhost:54322/iinwentory?schema=public
# Supabase (Project settings → Database → Connection string → URI):
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public
DATABASE_URL="postgresql://iinwentory:iinwentory@localhost:54322/iinwentory?schema=public"

# ── Supabase (used by server when issuing/verifying user JWTs) ─────────
# Leave blank to fall back to the local-only auth flow that issues HS256
# JWTs signed with SUPABASE_JWT_SECRET. When connecting to a real Supabase
# project, set SUPABASE_URL/ANON/SERVICE_ROLE/JWT_SECRET to the values from
# Project Settings → API. Tokens issued by Supabase Auth will then verify
# transparently.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Must match the JWT secret of the Supabase project (or any 32+ char string
# in pure-local mode). Used to sign + verify access tokens.
SUPABASE_JWT_SECRET="CHANGE_ME_supabase_jwt_secret_at_least_32_chars"

# ── Google Sign-In ──────────────────────────────────────────────────────
# OAuth 2.0 Web application client id from Google Cloud Console
# (APIs & Services → Credentials). The SAME value goes in the frontend's
# VITE_GOOGLE_CLIENT_ID. The server uses it as the audience it verifies
# incoming Google ID tokens against. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=""

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ADVANCED_MONTHLY=""
STRIPE_PRICE_ADVANCED_YEARLY=""
STRIPE_PRICE_ULTRA_MONTHLY=""
STRIPE_PRICE_ULTRA_YEARLY=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_YEARLY=""

# ── Email (Resend SMTP) ─────────────────────────────────────────────────
# Create an API key at https://resend.com/api-keys and verify the
# iinwentory.com domain at https://resend.com/domains. SMTP_USER is the
# literal string "resend"; SMTP_PASS is the Resend API key (starts with re_).
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS=""
SMTP_FROM="iinwentory <noreply@iinwentory.com>"

# ── URLs ────────────────────────────────────────────────────────────────
APP_URL="http://localhost:7745"
FRONTEND_URL="http://localhost:5173"
MARKETING_URL="http://localhost:3001"

# ── Server ──────────────────────────────────────────────────────────────
PORT=7745
